# ani-tupi Configuration Example
# Copy this to .env and customize as needed

# ============================================================================
# PLUGIN/SCRAPER CONFIGURATION
# ============================================================================

# Priority order for scraper sources (comma-separated, no spaces)
# First in list has highest priority
# Available: animesdigital, animefire, animeplayer, animesonlinecc
ANI_TUPI__PLUGINS__PRIORITY_ORDER=animesdigital,animeplayer,animefire,animesonlinecc

# Disabled plugins (comma-separated list of plugin names to disable)
# Example: ANI_TUPI__PLUGINS__DISABLED_PLUGINS=animesonlinecc,animefire
# ANI_TUPI__PLUGINS__DISABLED_PLUGINS=

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Browser pool size (number of Firefox instances to keep warm)
# Default: 3, Range: 1-5
ANI_TUPI__PERFORMANCE__BROWSER_POOL_SIZE=3

# HTTP request timeout (seconds)
# Default: 15, Range: 5-60
ANI_TUPI__PERFORMANCE__HTTP_TIMEOUT=15

# Maximum concurrent scrapers
# Default: 3, Range: 1-10
ANI_TUPI__PERFORMANCE__MAX_CONCURRENT_SCRAPERS=3

# ============================================================================
# CACHE SETTINGS
# ============================================================================

# Default cache TTL (hours)
# Default: 168 (7 days), Range: 1-720 (30 days)
ANI_TUPI__PERFORMANCE__DEFAULT_TTL_HOURS=168

# Cache type: memory, disk, or hybrid
# Default: disk
ANI_TUPI__PERFORMANCE__CACHE_TYPE=disk

# ============================================================================
# ANILIST INTEGRATION
# ============================================================================

# Prefer English titles in AniList
# Default: false
ANI_TUPI__ANILIST__PREFER_ENGLISH_TITLE=false

# Auto-discover AniList ID via fuzzy matching
# Default: true
ANI_TUPI__CACHE__ANILIST_AUTO_DISCOVER=true

# Fuzzy matching threshold (0-100, higher = stricter)
# Default: 90
ANI_TUPI__CACHE__ANILIST_FUZZY_THRESHOLD=90

# ============================================================================
# SEARCH SETTINGS
# ============================================================================

# Minimum words for progressive search
# Default: 1, Range: 1-10
ANI_TUPI__SEARCH__PROGRESSIVE_SEARCH_MIN_WORDS=1

# Maximum results to show initially
# Default: 10, Range: 5-50
ANI_TUPI__SEARCH__TOP_RESULTS_LIMIT=10

# ============================================================================
# MANGA SETTINGS (if using manga_tupi)
# ============================================================================

# Preferred manga sources
# Default: mangalivre,mugiwaras,mangadex
ANI_TUPI__MANGA__PREFERRED_SOURCES=mangalivre,mugiwaras,mangadex

# PDF reader to use (or auto-detect if empty)
# Options: zathura, evince, okular, mupdf
# ANI_TUPI__MANGA__PDF_READER=zathura

# Auto-create PDF after downloading
# Default: true
ANI_TUPI__MANGA__AUTO_CREATE_PDF=true

# Auto-delete read chapters
# Default: true
ANI_TUPI__MANGA__AUTO_DELETE_READ_CHAPTERS=true
